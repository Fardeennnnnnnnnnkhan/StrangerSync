<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Omegle Clone</title>
    <link href="/css/style.css" rel="stylesheet" />
    <style>
      html,
      body {
        margin: 0;
        padding: 0;
        height: 100%;
        overflow: hidden;
        font-family: "Segoe UI", sans-serif;
        background-color: black;
      }

      #globeViz {
        position: fixed;
        top: 0;
        left: 0;
        z-index: 0;
        width: 100vw;
        height: 100vh;
      }

      .overlay {
        position: relative;
        z-index: 10;
        width: 100%;
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        flex-direction: column;
        text-align: center;
        padding: 1rem;
      }

      .overlay h1 {
        font-size: 2.5rem;
        font-weight: bold;
        color: white;
        margin-bottom: 1rem;
      }

      .overlay p {
        font-size: 1.2rem;
        color: #ccc;
        max-width: 600px;
        margin-bottom: 2rem;
      }

      .start-button {
        background-color: #6366f1;
        color: white;
        padding: 0.8rem 2rem;
        border: none;
        border-radius: 0.5rem;
        font-size: 1rem;
        font-weight: bold;
        cursor: pointer;
        transition: background 0.2s ease;
      }

      .start-button:hover {
        background-color: #4f46e5;
      }
    </style>
  </head>
  <script>
    const phrases = [
      "Connect with people around the world instantly.",
      "Your random chat starts here!",
      "Meet someone new, anytime, anywhere.",
    ];

    let part = 0;
    let j = 0;
    let isDeleting = false;
    const element = document.getElementById("typing-text");

    function type() {
      const currentPhrase = phrases[part];
      const updatedText = isDeleting
        ? currentPhrase.substring(0, j--)
        : currentPhrase.substring(0, j++);

      element.innerHTML = updatedText;

      if (!isDeleting && i === currentPhrase.length) {
        isDeleting = true;
        setTimeout(type, 1200);
      } else if (isDeleting && j === 0) {
        isDeleting = false;
        part = (part + 1) % phrases.length;
        setTimeout(type, 200);
      } else {
        setTimeout(type, isDeleting ? 50 : 100);
      }
    }

    type();
  </script>

  <body>
    <!-- 🌍 3D Interactive Globe -->
    <div id="globeViz"></div>

    <!-- 🧾 Foreground Overlay Content -->
    <!-- 🧾 Foreground Overlay Content -->
    <div class="overlay">
      <h1
        style="
          font-size: 3rem;
          font-weight: 900;
          letter-spacing: 1px;
          color: white;
          margin-bottom: 1.5rem;
          font-family: 'Segoe UI', sans-serif;
          text-shadow: 0 4px 32px rgba(0, 0, 0, 0.5);
        "
      >
        Welcome to StrangerSync
      </h1>

      <p
        id="typing-text"
        style="
          font-size: 1.35rem;
          color: #e0e0e0;
          max-width: 600px;
          margin-bottom: 2.5rem;
          line-height: 1.6;
          padding: 1rem 2rem;
          border-radius: 1rem;
          font-family: 'Segoe UI', sans-serif;
          white-space: pre-wrap;
          min-height: 80px;
        "
      ></p>

      <a
        href="/chat"
        class="start-button"
        style="
          background: rgba(99, 102, 241, 0.15);
          color: #fff;
          border: 2px solid #6366f1;
          padding: 0.8rem 2.5rem;
          font-size: 1.1rem;
          font-weight: 700;
          border-radius: 0.75rem;
          backdrop-filter: blur(2px);
          transition: all 0.25s;
          box-shadow: 0 2px 16px rgba(99, 102, 241, 0.15);
          text-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
          cursor: pointer;
        "
      >
        Start Chat
      </a>
    </div>

    <!-- Three.js and Globe.gl scripts -->
    <script src="https://unpkg.com/three@0.150.1/build/three.min.js"></script>
    <script src="https://unpkg.com/globe.gl"></script>

    <script>
      // Wait for DOM and scripts to load
      window.onload = function () {
        const globe = Globe()(document.getElementById("globeViz"))
          .globeImageUrl(
            "https://unpkg.com/three-globe/example/img/earth-night.jpg"
          )

          .backgroundColor("#000000")
          .showAtmosphere(true)
          .atmosphereColor("#ffffff")
          .atmosphereAltitude(0.25)
          .pointOfView({ lat: 22.3, lng: 114.1, altitude: 2 }, 0);

        // Set autoRotate on the controls
        globe.controls().autoRotate = true;
        globe.controls().autoRotateSpeed = 0.7;

        const ringData = [
          { lat: 37.8, lng: -122.4 }, // USA
          { lat: 28.6, lng: 77.2 }, // India
          { lat: 40.7, lng: -74.0 }, // United States
          { lat: 51.5, lng: -0.12 }, // United Kingdom
          { lat: 48.8, lng: 2.3 }, // France
          { lat: -33.9, lng: 151.2 }, // Australia
          { lat: 35.7, lng: 139.7 }, // Japan
          { lat: -23.5, lng: -46.6 }, // Brazil
          { lat: 55.7, lng: 37.6 }, // Russia
          { lat: 52.3, lng: 4.9 }, // Netherlands
          { lat: 19.4, lng: -99.1 }, // Mexico
          { lat: 31.2, lng: 121.5 }, // China
          { lat: -34.6, lng: -58.4 }, // Argentina
          { lat: 43.6, lng: -79.4 }, // Canada
          { lat: 41.9, lng: 12.5 }, // Italy
          { lat: 1.3, lng: 103.8 }, // Singapore
          { lat: 13.7, lng: 100.5 }, // Thailand
          { lat: 60.2, lng: 24.9 }, // Finland
          { lat: 38.7, lng: -9.1 }, // Portugal
          { lat: -6.2, lng: 106.8 }, // Indonesia
          { lat: 25.2, lng: 55.3 }, // UAE
          { lat: -33.4, lng: -70.6 }, // Chile
          { lat: 50.1, lng: 8.6 }, // Germany
          { lat: 39.5, lng: -0.4 }, // Spain
          { lat: 35.6, lng: 51.4 }, // Iran
          { lat: 33.6, lng: 73.0 }, // Pakistan
          { lat: 21.0, lng: 105.8 }, // Vietnam
          { lat: -35.3, lng: 149.1 }, // Canberra (Australia - other side)
          { lat: -18.1, lng: 178.4 }, // Fiji
          { lat: 43.2, lng: 76.9 }, // Kazakhstan
          { lat: -36.8, lng: 174.7 }, // New Zealand
          { lat: 5.6, lng: -0.2 }, // Ghana
        ];

        globe
          .ringsData(ringData)
          .ringColor(() => ["#00ffff", "#00aaff"]) // cyan-like glow
          .ringMaxRadius(4)
          .ringPropagationSpeed(2)
          .ringRepeatPeriod(700);

        const arcsData = [
          {
            startLat: 28.6139,
            startLng: 77.209,
            endLat: 3.139,
            endLng: 101.6869,
            color: ["#00ffff"],
          },
          {
            startLat: 51.5072,
            startLng: -0.1276,
            endLat: -33.8688,
            endLng: 151.2093,
            color: ["#00aaff"],
          },
        ];

        globe
          .arcsData(arcsData)
          .arcColor("color")
          .arcAltitude(0.2)
          .arcStroke(1)
          .arcDashLength(0.5)
          .arcDashGap(2)
          .arcDashAnimateTime(1500)
          .showAtmosphere(true)
          .atmosphereColor("#00ffff")
          .atmosphereAltitude(0.2);
        globe
          .pointsData(gData)
          .pointAltitude("size")
          .pointColor("color")
          .pointRadius(0.5)
          .pointResolution(12);
      };

      // Typing effect for the paragraph
      const typingText =
        "Connect with people around the world instantly. Your random chat starts here!";
      let i = 0;
      function typeWriter() {
        if (i <= typingText.length) {
          document.getElementById("typing-text").innerHTML =
            typingText.slice(0, i) + '<span style="opacity:0.5;">|</span>';
          i++;
          setTimeout(typeWriter, 35);
        } else {
          document.getElementById("typing-text").innerHTML = typingText;
        }
      }
      typeWriter();

      // Button hover effect
      const btn = document.querySelector(".start-button");
      btn.addEventListener("mouseenter", () => {
        btn.style.background = "rgba(99,102,241,0.35)";
        btn.style.color = "#fff";
        btn.style.boxShadow = "0 4px 32px rgba(99,102,241,0.25)";
        btn.style.transform = "scale(1.05)";
      });
      btn.addEventListener("mouseleave", () => {
        btn.style.background = "rgba(99,102,241,0.15)";
        btn.style.color = "#fff";
        btn.style.boxShadow = "0 2px 16px rgba(99,102,241,0.15)";
        btn.style.transform = "scale(1)";
      });
    </script>
  </body>
</html>
